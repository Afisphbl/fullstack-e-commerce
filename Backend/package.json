{
  "name": "e-commerce-api",
  "version": "1.0.0",
  "description": "Production-grade E-Commerce REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'Verifying backend code...' && node -c server.js && node -c app.js && echo 'Build successful! Backend is ready for production.'",
    "build:verify": "node -c server.js && node -c app.js && node -c utils/chapaService.js && node -c controllers/paymentController.js && node -c routes/paymentRoutes.js",
    "test:chapa": "node utils/testChapa.js",
    "import-data": "node utils/importData.js --import",
    "delete-data": "node utils/importData.js --delete",
    "migrate-messages": "node utils/migrateMessages.js",
    "fix-contact-settings": "node utils/fixContactSettings.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "sharp": "^0.33.1",
    "slugify": "^1.6.6",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "nodemon": "^3.0.2"
  }
}
