# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env for local development
# Copy this file to .env.production for production builds
# 
# IMPORTANT: Never commit .env files with real values to version control
# ============================================================================

# ----------------------------------------------------------------------------
# API CONFIGURATION
# ----------------------------------------------------------------------------
# Backend API base URL
# Development: http://localhost:5000/api/v1
# Production: https://your-backend-domain.com/api/v1
VITE_API_URL=http://localhost:5000/api/v1

# ----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# ----------------------------------------------------------------------------
# Application environment (development, staging, production)
VITE_APP_ENV=development

# Application name (used in meta tags and PWA)
VITE_APP_NAME=Seid-Electronics

# Application URL (used for canonical URLs and social sharing)
VITE_APP_URL=http://localhost:8080

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
# Enable/disable features based on environment
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false
VITE_ENABLE_PWA=false

# ----------------------------------------------------------------------------
# THIRD-PARTY SERVICES (Optional)
# ----------------------------------------------------------------------------
# Google Analytics Measurement ID (e.g., G-XXXXXXXXXX)
# VITE_GA_MEASUREMENT_ID=

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=

# ----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# ----------------------------------------------------------------------------
# Enable strict security headers (recommended for production)
VITE_ENABLE_STRICT_CSP=false

# ----------------------------------------------------------------------------
# PERFORMANCE CONFIGURATION
# ----------------------------------------------------------------------------
# Enable service worker for offline support
VITE_ENABLE_SERVICE_WORKER=false

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# 1. All frontend environment variables MUST start with VITE_ prefix
# 2. Never store secrets or API keys in frontend environment variables
# 3. Frontend env vars are embedded in the build and visible to users
# 4. Use backend environment variables for sensitive data
# 5. Restart dev server after changing environment variables
